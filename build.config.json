{
  "appId": "com.racestrategist.telemetry-agent",
  "productName": "iRacing Telemetry Agent",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.cjs",
    "preload.js",
    "server.js",
    "sdk-worker.js",
    "renderer/**/*",
    "assets/**/*"
  ],
  "win": {
    "target": ["portable"],
    "icon": "assets/icon.png",
    "artifactName": "${productName}-${version}-portable.exe"
  },
  "portable": {
    "artifactName": "${productName}-${version}-portable.exe"
  }
}
