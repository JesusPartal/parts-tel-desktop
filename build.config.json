{
  "appId": "com.racestrategist.telemetry-agent",
  "productName": "iRacing Telemetry Agent",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.cjs",
    "preload.js",
    "server.js",
    "sdk-worker.js",
    "renderer/**/*",
    "assets/**/*"
  ],
  "win": {
    "target": ["portable", "nsis"],
    "icon": "assets/icon.png",
    "artifactName": "${productName}-${version}-setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
